DATABASE_URI=mongodb://localhost:27017/temporalai
JWT_SECRET=your-super-secret-jwt-key-change-this
PORT=5000
FRONTEND_URL=https://ixnel-frontend.vercel.app

# RunPod
RUNPOD_API_KEY=your_runpod_api_key
